#   - qemu-kvm
#   - libvirt-daemon-system
#   - libvirt-clients
#   - bridge-utils
#   - virtinst
#   - virt-manager
# openvpn_core_packages:
#   - openvpn
# openvpn_network_manager_packages:
#   - network-manager-openvpn
# virt_manager_default_uri: qemu:///system
